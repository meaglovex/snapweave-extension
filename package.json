{
  "name": "snapweave",
  "version": "0.2.0",
  "private": true,
  "description": "A Chrome extension for WeChat-style page capture, annotation, and export.",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite build --watch",
    "build": "npm run clean && vite build",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && node ./scripts/package.mjs"
  },
  "keywords": [
    "chrome-extension",
    "screenshot",
    "annotation",
    "manifest-v3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.1.24",
    "@eslint/js": "^9.25.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
